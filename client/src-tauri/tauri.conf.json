{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jamapp",
  "version": "0.1.0",
  "identifier": "com.fkb.jamapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "jamapp",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["jamapp"]
      }
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3RkMwOUEzQzUwMDQ4MzIKUldReVNBREZvd244TndReW15WWpjWENLNldkME9iYnRQZTc3SDVvbkQ2UHhKZUtNSndvOFJkU2cK",
      "endpoints": [
        "https://github.com/ferhankb/jamapp/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  }
}
