# Copy to server/.env and fill in. Gitignored.

# Local dev: postgres on host :5433 (from docker-compose).
# In docker-compose, this is overridden to postgres://jamapp:jamapp@db:5432/jamapp
DATABASE_URL=postgres://jamapp:jamapp@localhost:5433/jamapp?sslmode=disable

# HMAC secret for JWTs. Generate your own: openssl rand -hex 32
JWT_SECRET=change-me

# YouTube Data API v3 key. Create one at https://console.cloud.google.com/.
YOUTUBE_API_KEY=
